# ============================================================
# Amazon Product Data Automation - Environment Configuration
# ============================================================
# Copy this file to .env and customize as needed
# DO NOT commit .env with real secrets to version control!

# ============================================================
# PostgreSQL Database
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=amazon_research
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full connection URL used by the backend and worker containers
DATABASE_URL=postgresql://postgres:postgres@db:5432/amazon_research

# ============================================================
# Redis (Message Broker + Cache)
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# Security / JWT Configuration
# ============================================================
# IMPORTANT: Change this to a strong random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=8f95c477be7e3c98d67a1bf6bc537bc2851a8f90ab61c8db1f3b23c21aef42bb
JWT_ALGORITHM=HS256
# Token expiry in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# Playwright Scraper Configuration
# ============================================================
# Set to True for production / Docker environments
PLAYWRIGHT_HEADLESS=True
# Random delay range between page requests (seconds)
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=5
# Maximum time to wait for a page to load (milliseconds)
PAGE_TIMEOUT=30000

# ============================================================
# Application Ports
# ============================================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ============================================================
# Frontend (Next.js) - Public environment variables
# ============================================================
# When running with Docker Compose, localhost:8000 is accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ============================================================
# Optional: CORS and Allowed Origins
# ============================================================
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ============================================================
# Optional: Email Notifications (SMTP)
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=Amazon Research Assistant <your-email@gmail.com>
